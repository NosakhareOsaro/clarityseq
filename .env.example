# =============================================================================
# ClaritySeq — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in all required values before running.
# NEVER commit .env to version control — it is listed in .gitignore.
#
# Required variables are marked [REQUIRED].
# Optional variables have sensible defaults shown.
# For NHS England labs, ClinVar submission variables are MANDATORY per ACGS 2024.
# =============================================================================

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS region where all resources are deployed (Batch, S3, RDS, ECR)
# Recommended: eu-west-2 for NHS England compliance (UK data residency)
AWS_REGION=eu-west-2

# [REQUIRED] Your 12-digit AWS account ID
# Used by Terraform to construct ARNs and ECR repository URLs
AWS_ACCOUNT_ID=

# =============================================================================
# Database — PostgreSQL 16
# =============================================================================

# [REQUIRED] PostgreSQL 16 async DSN (asyncpg driver)
# Local dev: postgresql+asyncpg://clarityseq:pass@localhost:5432/clarityseq
# AWS RDS: postgresql+asyncpg://user:pass@<rds-endpoint>:5432/clarityseq
# The db.t4g.micro RDS instance is configured in terraform/rds.tf
POSTGRES_DSN=postgresql+asyncpg://user:pass@localhost:5432/clarityseq

# [REQUIRED] Redis 7.x URL — used as Celery broker and results backend
# Local dev: redis://localhost:6379/0
# AWS ElastiCache: redis://<cluster-endpoint>:6379/0
# Database 0 is used by Celery; reserve DB 1+ for application caching
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# External APIs — Annotation and Clinical Databases
# =============================================================================

# ClinVar FTP base URL — used by the reclassification daemon to download weekly diffs
# The daemon (reclassification/daemon.py) checks for new submissions every Monday
# Do not change unless NCBI changes the FTP structure
CLINVAR_FTP_URL=ftp://ftp.ncbi.nlm.nih.gov/pub/clinvar/

# PanelApp Genomics England API — gene panel lookups for variant prioritisation
# Used by annotation/panelapp_client.py to fetch green-rated genes per panel
# API v1 is stable; v2 is in beta as of 2026
PANELAPP_BASE_URL=https://panelapp.genomicsengland.co.uk/api/v1

# CPIC (Clinical Pharmacogenomics Implementation Consortium) API
# Used by pgx/cpic_client.py to fetch gene-drug dosing guidelines
# Required when run_pgx=true in nextflow.config
CPIC_API_URL=https://api.cpicpgx.org/v1

# PharmVar API — CYP2D6 and other pharmacogene allele nomenclature
# Used by pgx/pharmvar_client.py to resolve star allele nomenclature
# Cyrius calls star alleles; PharmVar maps them to activity scores
PHARMVAR_API_URL=https://www.pharmvar.org/api-service

# ClinGen CSpec (Classification Specification) registry API
# Used by bayesacmg/src/bayesacmg/vcep_client.py to look up VCEP rules
# Returns VCEP-specific rule modifications for gene-specific classification
# Reference: https://cspec.genome.network/cspec/ui/svi/
CLINGEN_CSPEC_URL=https://cspec.genome.network/cspec/api/svi/

# =============================================================================
# GA4GH Standards — Beacon v2.1.1 and FHIR R4
# =============================================================================

# [REQUIRED for production] JWT signing secret for Beacon v2.1.1 API
# Must be ≥ 32 characters; use a cryptographically random value
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Used by beacon_api/auth/passports.py to sign GA4GH Passports
BEACON_JWT_SECRET=

# EGA (European Genome-phenome Archive) Beacon registration URL
# Used to register this Beacon instance with the EGA network
# Required for GA4GH Beacon Network participation
BEACON_EGA_REGISTRATION_URL=https://ega-archive.org/beacon-registration

# [REQUIRED for clinical reporting] HL7 FHIR R4 server base URL
# Used by reclassification/fhir_task.py to create FHIR Task resources
# per Genomics Reporting IG v3.0.0 recontact workflow
# Example: http://hapi.fhir.org/baseR4 (test), https://your-fhir-server/fhir (prod)
FHIR_SERVER_URL=

# FHIR Genomics Reporting IG version — do NOT change without testing
# v3.0.0 is required for the recontact Task IG profile used by the daemon
FHIR_GENOMICS_IG_VERSION=3.0.0

# GA4GH VRS SeqRepo URL — used for canonical variant representation
# Used by beacon_api/vrs_utils.py for VRS v2.0 identifier generation
# Public instance for development; deploy private instance for PHI
VRS_SEQREPO_URL=https://services.genomicmedlab.org/seqrepo

# =============================================================================
# Notifications — Reclassification Alerts
# =============================================================================

# [OPTIONAL] Slack webhook for reclassification notifications
# The daemon (reclassification/notifier.py) posts when ClinVar reclassifies
# a variant that has been reported to a patient
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# [OPTIONAL] SendGrid API key for email notifications
# Used as fallback/alternative to Slack for clinical reclassification alerts
# Required if NHS lab needs email audit trail for reclassification events
SENDGRID_API_KEY=

# =============================================================================
# ClinVar Submission — MANDATORY for NHS England Laboratories (ACGS 2024)
# =============================================================================
# ACGS 2024 v1.2 (Durkie et al. 2024) mandates ClinVar submission for all
# laboratories accredited under NHS England Genomic Medicine Service.
# See reclassification/clinvar_submitter.py for the submission workflow.

# [REQUIRED for NHS labs] NCBI E-utilities API key
# Register at: https://www.ncbi.nlm.nih.gov/account/
# Required for all ClinVar API calls (rate limit 10 req/s with key vs 3/s without)
NCBI_API_KEY=

# [REQUIRED for NHS labs] ClinVar submitter organisation ID
# Assigned by NCBI when your lab registers as a ClinVar submitter
# See: https://www.ncbi.nlm.nih.gov/clinvar/docs/submit/
CLINVAR_SUBMISSION_ORG_ID=

# =============================================================================
# Annotation Data Paths — Large Files (Do Not Commit)
# =============================================================================

# AlphaMissense pre-computed scores (Cheng et al. 2023, Science doi:10.1126/science.adg7492)
# ClinGen SVI approved as primary PP3/BP4 evidence in 2024
# Thresholds: ≥0.564 → PP3; ≤0.340 → BP4; ambiguous in between
# Download: gsutil cp gs://dm_alphamissense/AlphaMissense_hg38.tsv.gz /data/
# Must be tabix-indexed: tabix -s 1 -b 2 -e 2 AlphaMissense_hg38.tsv.gz
ALPHAMISSENSE_SCORES_PATH=/data/AlphaMissense_hg38.tsv.gz

# dbNSFP v4.7 database path (glob pattern for per-chromosome files)
# Contains AlphaMissense, ESM1b, REVEL, and 40+ other pathogenicity scores
# Download: https://sites.google.com/site/jpopgen/dbNSFP
# Used by VEP v111 dbNSFP plugin via annotation/dbnsfp_client.py
DBNSFP_DB_PATH=/data/dbNSFP4.7_variant.chr*.gz
