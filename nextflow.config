// =============================================================================
// ClaritySeq — nextflow.config
// =============================================================================
// Main Nextflow configuration for the ClaritySeq WGS clinical interpretation
// pipeline. This file configures all pipeline parameters, execution profiles,
// and infrastructure settings.
//
// DSL2 is required. Nextflow ≥ 24.x required.
//
// Usage:
//   nextflow run pipelines/wgs_grch38.nf -profile local
//   nextflow run pipelines/wgs_grch38.nf -profile test,docker
//   nextflow run pipelines/wgs_grch38.nf -profile aws
//
// Every parameter has a comment explaining:
//   - What it does
//   - Why this default was chosen
//   - Where to get the reference file (if applicable)
// =============================================================================

nextflow.enable.dsl = 2

// =============================================================================
// Pipeline parameters
// All defaults are null — required params must be provided at runtime
// or via a -params-file JSON/YAML file.
// =============================================================================

params {

    // ── Input / Output ────────────────────────────────────────────────────────

    input             = null
    // Sample sheet CSV. Columns: sample,fastq_1,fastq_2,sex,affected,ped_file
    // See docs/guides/quickstart.md for format

    outdir            = "results"
    // Output directory. Structured as: outdir/{sample}/{analysis_type}/

    genome            = "GRCh38"
    // Reference genome build. Supported: GRCh38, T2T-CHM13v2.0
    // GRCh38 is the NHS England GMS mandated primary reference

    // ── Aligners ──────────────────────────────────────────────────────────────

    dragmap_reference = null
    // DRAGMAP hash table directory (built with dragen-os --build-hash-table)
    // This is the PRIMARY aligner reference. Different format from FASTA.
    // Pre-built hg38 hash tables: s3://broad-references/hg38/v0/dragmap/
    // BQSR is NOT run when using DRAGMAP (BQD model in HaplotypeCaller
    // replaces BQSR in DRAGEN-GATK mode — see conf/dragen_gatk.config)
    // One-time build command:
    //   dragen-os --build-hash-table /path/to/output --ht-reference hg38.fa

    reference_fasta   = null
    // GRCh38 FASTA — used only with -profile bwa_mem2 (fallback)
    // and for T2T liftover step
    // Must have .fai and .dict files alongside it

    reference_fai     = null
    // FASTA index (.fai) — auto-detected if alongside reference_fasta

    reference_dict    = null
    // Sequence dictionary (.dict) — required by GATK tools

    // ── gnomAD v4.1 ───────────────────────────────────────────────────────────

    gnomad_vcf        = null
    // gnomAD v4.1 sites VCF (released April 19, 2024)
    // IMPORTANT: Use v4.1, NOT v4.0. v4.0 had an allele number
    // calculation bug fixed in v4.1. v4.1 contains 807,162 individuals
    // (730,947 exomes + 76,215 genomes including 416,555 UK Biobank).
    // Reference: https://gnomad.broadinstitute.org/news/2024-05-gnomad-v4-1-updates/
    // BA1 threshold: AF > 0.05 (5%) per ACMG 2015; BS1: AF > 0.01
    // PM2 evidence: AF < 0.0001 or absent — see ADR-006 (PM2 Supporting, not Moderate)

    gnomad_vcf_tbi    = null
    // gnomAD VCF tabix index (.tbi) — required for GATK interval queries

    // ── AlphaMissense ─────────────────────────────────────────────────────────

    alphamissense_tsv = null
    // Pre-computed AlphaMissense scores (Cheng et al. 2023, Science)
    // ClinGen SVI approved for PP3/BP4 evidence in 2024
    // Thresholds: ≥0.564→PP3; ≤0.340→BP4; ambiguous otherwise
    // These thresholds were calibrated against ClinVar pathogenic/benign
    // variants (see calibration/ directory and bayesacmg/calibration.py)
    // Download: gs://dm_alphamissense/AlphaMissense_hg38.tsv.gz (~2.7 GB)
    // Must be tabix-indexed before use:
    //   tabix -s 1 -b 2 -e 2 AlphaMissense_hg38.tsv.gz

    alphamissense_tbi = null
    // AlphaMissense tabix index

    // ── VEP v111 ──────────────────────────────────────────────────────────────

    vep_cache_dir     = null
    // VEP cache directory — must be version 111 exactly
    // Download: vep_install -a c -s homo_sapiens -y GRCh38 -c /path/to/cache --CACHE_VERSION 111

    vep_cache_version = 111
    // VEP cache must be v111. Do NOT use older versions.
    // v111 includes improved MANE Select annotation and dbNSFP v4.7 support.
    // MANE Select is used as the primary clinical transcript per
    // ACGS 2024 v1.2 and Morales et al. 2022 Nature PMID:35356062

    vep_genome        = "GRCh38"
    // VEP genome build — must match reference_fasta

    vep_species       = "homo_sapiens"
    // VEP species — always homo_sapiens for clinical WGS

    dbnsfp_db         = null
    // dbNSFP v4.7 database path (per-chromosome gz files, glob pattern)
    // Used by VEP dbNSFP plugin to annotate REVEL, ESM1b, AlphaMissense etc.
    // Version 4.7 is the minimum — includes AlphaMissense 2023 scores

    // ── Known sites (GATK) ────────────────────────────────────────────────────

    dbsnp_vcf         = null
    // dbSNP VCF — used for rs-ID annotation in VEP and GATK BQSR (bwa_mem2 only)
    // Use build 156 or later for GRCh38

    mills_vcf         = null
    // Mills and 1000G gold standard indels — used only in bwa_mem2 profile BQSR
    // Not used in DRAGEN-GATK mode (BQSR disabled)

    known_indels_vcf  = null
    // 1000G phase1 indels — used only in bwa_mem2 profile BQSR

    hapmap_vcf        = null
    // HapMap 3.3 — used for VQSR training in SNP tranche calibration

    omni_vcf          = null
    // 1000G Omni 2.5 — used for VQSR training

    thousand_genomes_vcf = null
    // 1000G phase3 — used for VQSR SNP tranche and ancestry inference (somalier)

    // ── Pangenome (HPRC) ──────────────────────────────────────────────────────

    pangenome_graph   = null
    // HPRC v1.1 pangenome graph in GBZ format (vg giraffe input)
    // Download: https://github.com/human-pangenomics/hpp_pangenome_resources
    // Required when run_pangenome=true

    pangenome_dist    = null
    // Pangenome distance index (.dist) for vg giraffe

    pangenome_min     = null
    // Pangenome minimizer index (.min) for vg giraffe

    // ── T2T-CHM13 v2.0 ───────────────────────────────────────────────────────

    t2t_reference     = null
    // T2T-CHM13 v2.0 FASTA — used in run_t2t arm
    // Download: https://github.com/marbl/CHM13

    crossmap_chain    = null
    // CrossMap chain file: CHM13v2.0 → GRCh38
    // Required for T2T→GRCh38 liftover step

    // ── ExpansionHunter ───────────────────────────────────────────────────────

    expansion_catalog = null
    // ExpansionHunter v5.0 repeat catalog JSON (60 loci)
    // Includes STR loci from STRipy 2024 thresholds
    // Path: data/expansion_hunter_catalog_v5.0_60loci.json

    // ── Pipeline arms ─────────────────────────────────────────────────────────

    run_deepvariant   = true
    // Run DeepVariant v1.8.0 in parallel with GATK4; merge via ensemble caller
    // Recommended: true. DeepVariant adds concordance checks and catches
    // variants GATK misses in difficult regions.

    run_deeptrio      = false
    // Enable for trio samples (requires PED file); uses DeepTrio v1.8.0
    // Automatically enabled when input contains parent-proband relationships

    run_mito          = true
    // GATK Mutect2 mito mode + Haplogrep3; follows ACGS 2024 §6
    // Adds ~5 min per sample; produces mt haplogroup and mito variant calls

    run_expansions    = true
    // ExpansionHunter v5.0 catalog (60 loci)
    // Adds ~10 min per sample; required for clinical WGS per ACGS 2024

    run_pgx           = true
    // Cyrius CYP2D6 SV + PharmVar + CPIC dosing recommendations
    // Adds ~15 min per sample; requires run_deepvariant=true for star allele calling

    run_pangenome     = false
    // vg giraffe HPRC alignment arm (resource-intensive; nightly CI only)
    // Requires pangenome_graph, pangenome_dist, pangenome_min
    // Minimum 32 CPUs and 256 GB RAM — see -profile pangenome

    run_t2t           = false
    // T2T-CHM13 v2.0 arm with GRCh38 liftover via CrossMap
    // Requires t2t_reference and crossmap_chain

    ancestry_vqsr     = true
    // Per-ancestry VQSR model selection via somalier ancestry inference
    // Groups samples by ancestry (EUR, AFR, EAS, SAS, AMR, OTH) and applies
    // ancestry-appropriate VQSR training resources
    // Improves VQSR calibration for non-European samples per ACGS 2024 §4.3

    // ── QC thresholds ─────────────────────────────────────────────────────────

    min_coverage      = 30
    // Minimum mean genome coverage (×) to pass QC
    // 30× is ACGS 2024 minimum for WGS clinical reporting
    // WGS at 30× gives 99.9% of the genome at ≥15× (sufficient for diploid calling)

    min_q30_bases     = 0.75
    // Minimum fraction of bases with Q≥30 (Phred quality score)
    // Q30 = 0.1% error rate; 75% Q30 is a standard NGS QC threshold

    min_pct_15x       = 0.95
    // Minimum fraction of genome covered at ≥15× (diploid calling threshold)
    // 15× is the minimum for reliable heterozygous variant detection

    // ── Output / Reporting ────────────────────────────────────────────────────

    save_reference    = false
    // Save reference genome to outdir (not needed if refs are on shared storage)

    save_trimmed      = false
    // Save fastp-trimmed FASTQ files (adds significant storage)

    save_aligned      = true
    // Save final sorted+marked-duplicate BAM/CRAM files

    report_format     = "pdf"
    // Clinical report output format: pdf, html, or both
    // PDF is required for NHS GMS clinical reporting

    mane_select_only  = true
    // Report variants on MANE Select transcript only per ACGS 2024 v1.2
    // MANE Select is the primary clinical transcript; do NOT report on
    // non-MANE transcripts without clinical justification

    // ── Email / Notifications ─────────────────────────────────────────────────

    email             = null
    // Email address for pipeline completion notification (null = disabled)

    email_on_fail     = null
    // Email address for pipeline failure notification

    monochrome_logs   = false
    // Disable ANSI colour codes in log output (for CI environments)

    // ── Pipeline metadata ─────────────────────────────────────────────────────

    pipeline_version  = "0.1.0"
    // ClaritySeq version — do not change manually; set by release process

    schema_ignore_params = "pipeline_version"
    // Parameters to ignore during JSON schema validation

}

// =============================================================================
// Process defaults
// =============================================================================
process {
    // Default container — pipeline-specific processes use their own containers
    // (defined in each module's main.nf)
    container = "clarityseq/pipeline:0.1.0"

    // Default error strategy: retry once, then fail
    errorStrategy = { task.exitStatus in [1, 137, 140, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 1

    // Import process labels from conf/base.config
}

// =============================================================================
// Execution profiles
// Profiles can be combined: -profile test,docker
// =============================================================================
profiles {

    // ─────────────────────────────────────────────────────────────────────────
    // test — chr22 only; validates pipeline without full genome data
    // Use this profile for CI/CD and quick development testing
    // ─────────────────────────────────────────────────────────────────────────
    test {
        includeConfig 'conf/test.config'

        params {
            // chr22 test data — small enough for CI (chr22 is ~51 Mb)
            // These paths point to publicly available test data
            input             = "https://raw.githubusercontent.com/nf-core/test-datasets/sarek/testdata/samplesheet_test.csv"
            outdir            = "results/test"

            // chr22 subsetted DRAGMAP reference (built from chr22 only)
            // Built from: hg38_chr22.fa using dragen-os --build-hash-table
            dragmap_reference = "https://pub.test-data.clarityseq.io/dragmap_chr22/"
            reference_fasta   = "https://raw.githubusercontent.com/nf-core/test-datasets/sarek/reference/genome.fasta"

            // Minimal gnomAD — chr22 sites only (reduced file size for CI)
            gnomad_vcf        = "https://pub.test-data.clarityseq.io/gnomad_v4.1_chr22.vcf.gz"

            // AlphaMissense chr22 subset
            alphamissense_tsv = "https://pub.test-data.clarityseq.io/AlphaMissense_chr22.tsv.gz"

            // Disable resource-intensive arms in CI
            run_pangenome     = false  // Requires 32 CPUs + 256 GB — too large for CI
            run_t2t           = false  // Requires T2T reference — not in test data
            run_deeptrio      = false  // Requires PED file — not in test samplesheet
            ancestry_vqsr     = false  // Requires multi-sample cohort — not in test

            // Resource caps for CI (GitHub Actions runners have 8 CPUs, 16 GB RAM)
            max_cpus          = 8
            max_memory        = "14.GB"
            max_time          = "6.h"
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // local — Docker containers; DRAGMAP primary; for local development
    // ─────────────────────────────────────────────────────────────────────────
    local {
        // Use Docker for all processes on local workstation
        docker.enabled      = true
        docker.runOptions   = '-u $(id -u):$(id -g)'  // Run as current user
        singularity.enabled = false

        params {
            max_cpus   = 16         // Adjust to your local machine's CPU count
            max_memory = "64.GB"    // Adjust to your local machine's RAM
            max_time   = "48.h"
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // docker — Enable Docker (combine with other profiles)
    // ─────────────────────────────────────────────────────────────────────────
    docker {
        docker.enabled      = true
        docker.runOptions   = '-u $(id -u):$(id -g)'
        singularity.enabled = false
        conda.enabled       = false
    }

    // ─────────────────────────────────────────────────────────────────────────
    // aws — AWS Batch with Spot fleet; ECR images; S3 staging
    // Configure AWS credentials in .env before using this profile
    // ─────────────────────────────────────────────────────────────────────────
    aws {
        includeConfig 'conf/aws.config'

        // AWS Batch executor
        process.executor      = 'awsbatch'

        // Use Docker (ECR images) on AWS Batch
        docker.enabled        = true
        docker.runOptions     = '--no-healthcheck'  // Batch manages health
        singularity.enabled   = false

        params {
            // AWS Batch Job Queue — created by terraform/batch.tf
            // Spot fleet for cost savings (90% cheaper than on-demand)
            awsqueue          = "clarityseq-spot"
            awsregion         = "eu-west-2"

            // S3 buckets — created by terraform/s3.tf
            // All intermediate files are staged through S3
            work_dir          = "s3://clarityseq-nextflow-work"
            outdir            = "s3://clarityseq-results"

            max_cpus          = 96      // c5.24xlarge: 96 vCPU
            max_memory        = "192.GB"
            max_time          = "72.h"
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // hpc — Singularity containers; SLURM executor
    // For NHS lab HPC clusters where Docker is not permitted
    // ─────────────────────────────────────────────────────────────────────────
    hpc {
        // Singularity/Apptainer is standard on HPC systems
        singularity.enabled     = true
        singularity.autoMounts  = true  // Auto-mount filesystem paths into container
        docker.enabled          = false

        // SLURM executor — adapt partition names to your cluster
        process.executor        = 'slurm'
        process.queue           = 'normal'  // SLURM partition name
        process.clusterOptions  = '--account=clarityseq'  // SLURM account

        params {
            max_cpus   = 128    // Adapt to your HPC node configuration
            max_memory = "512.GB"
            max_time   = "120.h"
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // bwa_mem2 — FALLBACK ONLY
    // Use only if DRAGMAP hash table references are unavailable.
    // BQSR IS run in this profile. This was the GATK Best Practice before
    // DRAGEN-GATK was released in 2021.
    //
    // WARNING: Do not use bwa_mem2 for new analyses. DRAGMAP (dragen-os)
    // is the current GATK Best Practice and produces higher sensitivity
    // on repetitive regions. BWA-MEM2 is retained for backwards
    // compatibility with legacy datasets only.
    // ─────────────────────────────────────────────────────────────────────────
    bwa_mem2 {
        params {
            run_bqsr = true   // BQSR IS enabled in BWA-MEM2 fallback mode
            // Note: run_bqsr=false is set in conf/dragen_gatk.config (the default)
            // Overriding it here re-enables BQSR for the BWA-MEM2 workflow

            max_cpus   = 32
            max_memory = "128.GB"
            max_time   = "72.h"
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // pangenome — enables HPRC pangenome alignment arm
    // Resource-intensive: minimum 32 CPUs and 256 GB RAM
    // Use for nightly CI and research analyses requiring pangenome comparison
    // ─────────────────────────────────────────────────────────────────────────
    pangenome {
        params {
            run_pangenome = true   // Enable vg giraffe pangenome arm

            // Pangenome graph files — HPRC v1.1
            // Download: https://github.com/human-pangenomics/hpp_pangenome_resources
            // pangenome_graph = "/data/hprc-v1.1-mc-grch38.gbz"
            // pangenome_dist  = "/data/hprc-v1.1-mc-grch38.dist"
            // pangenome_min   = "/data/hprc-v1.1-mc-grch38.min"

            // Resource minimums — do not reduce below these values
            // vg giraffe requires ~200 GB RAM for the HPRC v1.1 graph
            max_cpus   = 64
            max_memory = "256.GB"
            max_time   = "120.h"
        }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // singularity — Enable Singularity (combine with other profiles)
    // ─────────────────────────────────────────────────────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
    }

}

// =============================================================================
// Include supplementary configuration files
// =============================================================================
includeConfig 'conf/base.config'        // Per-label resource limits
includeConfig 'conf/dragen_gatk.config' // DRAGEN-GATK mode; BQSR disabled
includeConfig 'conf/resources.config'   // Per-process resource allocations

// =============================================================================
// Reporting and tracing
// =============================================================================
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
    fields  = "task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar"
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag.svg"
    overwrite = true
}

// =============================================================================
// Manifest
// =============================================================================
manifest {
    name            = "ClaritySeq"
    author          = "ClaritySeq Contributors"
    homePage        = "https://github.com/clarityseq/clarityseq"
    description     = "Production WGS clinical interpretation: DRAGEN-GATK + pangenome + Bayesian ACMG (ACGS 2024 v1.2)"
    mainScript      = "pipelines/wgs_grch38.nf"
    nextflowVersion = "!>=24.04.0"  // ! = hard requirement; will fail with older versions
    version         = "0.1.0"
    doi             = ""
}
