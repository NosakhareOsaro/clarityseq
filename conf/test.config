// =============================================================================
// GenomeForge — conf/test.config
// =============================================================================
// chr22-only test profile configuration.
// Used by -profile test for CI/CD and rapid development testing.
//
// chr22 is chosen because:
// 1. It is the smallest human autosome (~51 Mb), enabling fast test runs
// 2. It contains diverse variant types including STRs, CNVs, and coding variants
// 3. GIAB benchmark truth sets include chr22 high-confidence regions
// 4. All major OMIM disease genes on chr22 are included in test fixtures
//
// GitHub Actions CI runtime target: < 60 minutes for the full chr22 test
// Resources sized for GitHub Actions standard runner (8 CPUs, 16 GB RAM).
//
// DO NOT use this config for clinical analyses — chr22 only.
// =============================================================================

params {
    config_profile_name        = "GenomeForge chr22 test profile"
    config_profile_description = "Minimal test dataset using chr22 only. For CI/CD validation only — not for clinical use."
    config_profile_url         = "https://github.com/genomeforge/genome-forge"
    config_profile_contact     = "osaronosakhare@gmail.com"

    // ── Resource caps for CI runners ─────────────────────────────────────────

    max_cpus   = 8      // GitHub Actions standard runner: 2 CPUs (free) or 8 CPUs (paid)
    max_memory = "14.GB" // GitHub Actions standard runner: 7 GB (free) or 14 GB (paid)
    max_time   = "6.h"  // Maximum CI job duration before timeout

    // ── Test data — chr22 subsets ─────────────────────────────────────────────
    // These files are publicly available and small enough for CI use.
    // GIAB HG002 (NA24385) chr22 data is used as it has a published truth set.
    // Reference: Zook et al. 2019 Nature Biotechnology PMID:31406347

    input = "${projectDir}/tests/fixtures/samplesheet_chr22.csv"
    // Sample sheet with HG002 chr22 test data
    // Format: sample,fastq_1,fastq_2,sex,affected,ped_file

    outdir = "${params.outdir ?: 'results'}/test_chr22"

    // ── Reference files (chr22 subsets) ──────────────────────────────────────
    // All reference files are chr22-only subsets to minimise download times

    reference_fasta   = "https://pub.test-data.genomeforge.io/GRCh38_chr22.fa.gz"
    // GRCh38 chr22 FASTA — extracted from GRCh38.p14

    dragmap_reference = "https://pub.test-data.genomeforge.io/dragmap_GRCh38_chr22/"
    // DRAGMAP hash table built from GRCh38 chr22 FASTA
    // Built with: dragen-os --build-hash-table output/ --ht-reference GRCh38_chr22.fa

    // ── Annotation databases (chr22 subsets) ─────────────────────────────────

    gnomad_vcf        = "https://pub.test-data.genomeforge.io/gnomad.genomes.v4.1.sites.chr22.test.vcf.gz"
    // gnomAD v4.1 chr22 sites VCF — 1000 variant subset for fast testing

    alphamissense_tsv = "https://pub.test-data.genomeforge.io/AlphaMissense_hg38_chr22.tsv.gz"
    // AlphaMissense scores for chr22 genes only (~50k missense variants)

    vep_cache_dir     = "${HOME}/.vep"
    // VEP cache — install locally: vep_install -a c -s homo_sapiens -y GRCh38 --CACHE_VERSION 111
    // In CI: downloaded and cached between runs via GitHub Actions cache

    vep_cache_version = 111  // Must be 111 — see nextflow.config for rationale

    dbsnp_vcf         = "https://pub.test-data.genomeforge.io/dbsnp156_chr22.vcf.gz"
    // dbSNP build 156 chr22 subset

    // ── Known sites (for bwa_mem2 profile BQSR — not used in default DRAGEN-GATK mode) ───

    mills_vcf         = "https://pub.test-data.genomeforge.io/Mills_chr22.vcf.gz"
    known_indels_vcf  = "https://pub.test-data.genomeforge.io/1000G_indels_chr22.vcf.gz"

    // ── ExpansionHunter catalog (chr22 loci only) ─────────────────────────────

    expansion_catalog = "${projectDir}/tests/fixtures/expansion_hunter_chr22_loci.json"
    // Subset of the 60-loci catalog containing only chr22 STR loci
    // Loci on chr22: ATXN10 (SCA10), NOP56 (SCA36), and others

    // ── Disabled arms for CI (resource constraints) ───────────────────────────

    run_pangenome = false
    // Disabled: requires HPRC v1.1 graph (~100 GB) and 256 GB RAM

    run_t2t       = false
    // Disabled: requires T2T-CHM13 v2.0 reference (~3 GB) and CrossMap chain

    run_deeptrio  = false
    // Disabled: test samplesheet does not include parent samples

    ancestry_vqsr = false
    // Disabled: single-sample test cannot train per-ancestry VQSR model
    // VQSR requires minimum 30 samples per ancestry class

    // ── GIAB truth set for CI validation ─────────────────────────────────────

    giab_truth_vcf    = "https://pub.test-data.genomeforge.io/HG002_GRCh38_chr22_GIAB_v4.2.1.vcf.gz"
    // GIAB v4.2.1 HG002 truth VCF for chr22
    // Used by benchmark/run_hap_py.py to compute F1, precision, recall

    giab_truth_bed    = "https://pub.test-data.genomeforge.io/HG002_GRCh38_chr22_highconf_v4.2.1.bed"
    // GIAB high-confidence regions BED — only evaluate variants within these regions
    // CI passes if: SNP F1 ≥ 0.99, INDEL F1 ≥ 0.98 (ACGS 2024 validation threshold)
}

// =============================================================================
// Process resource overrides for test profile
// These override the per-label defaults in conf/base.config
// to fit within GitHub Actions runner constraints
// =============================================================================

process {
    // Limit maximum resources to avoid OOM on CI runners
    resourceLimits = [
        cpus  : 8,
        memory: 14.GB,
        time  : 6.h
    ]

    // Increase retries for test profile — CI can be flaky on public runners
    maxRetries = 2
}
