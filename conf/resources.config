// =============================================================================
// ClaritySeq — conf/resources.config
// =============================================================================
// Per-process resource allocations.
// Labels defined here map to the resource limits in conf/base.config.
//
// This file assigns a process label to every named Nextflow process.
// The actual memory/CPU/time limits come from the label definition in
// conf/base.config, modified by the active profile (test/local/aws/hpc).
//
// Process naming convention: MODULE_TOOL (e.g., DRAGMAP_ALIGN)
// All process names match the module names in modules/*/main.nf.
// =============================================================================

process {

    // ─────────────────────────────────────────────────────────────────────────
    // QC and preprocessing
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'FASTP' {
        label = 'process_medium'
        // fastp scales well to 8 threads; 16 GB RAM for large FASTQ pairs
        // fastp v0.23.4: adapter trimming + QC in a single pass
    }

    withName: 'FASTQC' {
        label = 'process_low'
        // FastQC is single-threaded in practice; low resource requirement
    }

    withName: 'MULTIQC' {
        label = 'process_low'
        // MultiQC aggregates QC reports; lightweight CPU task
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Alignment — PRIMARY: DRAGMAP (DRAGEN-GATK Best Practice)
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'DRAGMAP_ALIGN' {
        label = 'process_high'
        // DRAGMAP alignment of 30× WGS on 16 CPUs takes ~4-6 hours
        // Memory: ~40 GB for the DRAGMAP hash table + read buffer
        // DRAGMAP is the PRIMARY aligner — BWA-MEM2 is fallback only (ADR-001)
        ext.args = "--RGSM {sample} --RGLB lib1 --RGPL ILLUMINA --RGPU {flowcell}.{lane}"
        // Read group tags required for GATK downstream tools
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Alignment — FALLBACK: BWA-MEM2 (use only without DRAGMAP hash table)
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'BWAMEM2_MEM' {
        label = 'process_high'
        // BWA-MEM2 alignment: similar resources to DRAGMAP
        // Only activated with -profile bwa_mem2
        ext.args = "-Y -K 100000000"
        // -Y: soft-clip supplementary instead of hard-clip (GATK requirement)
        // -K 100000000: process 100M bases per thread for deterministic output
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Duplicate marking
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'GATK4_MARKDUPLICATES' {
        label = 'process_high'
        // MarkDuplicates reads entire BAM into memory — 60 GB provides headroom
        // for 30× WGS (~100 GB BAM size)
        ext.args = [
            "--ASSUME_SORT_ORDER coordinate",
            "--REMOVE_DUPLICATES false",
            // Keep duplicates in BAM; flag them with 0x400 bitflag
            // Removal is done by GATK HC -I filter, not here
            "--OPTICAL_DUPLICATE_PIXEL_DISTANCE 2500",
            // 2500 pixels: correct for patterned flowcells (NovaSeq 6000/X)
            // Use 100 for non-patterned (HiSeq 2500)
        ].join(" ")
    }

    // ─────────────────────────────────────────────────────────────────────────
    // BQSR — ONLY active with -profile bwa_mem2
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'GATK4_BASERECALIBRATOR' {
        label = 'process_medium'
        // BaseRecalibrator: ~16 GB RAM, benefits from multi-threading
        // Only runs when run_bqsr=true (bwa_mem2 profile)
        // DISABLED in DRAGEN-GATK mode — see conf/dragen_gatk.config
    }

    withName: 'GATK4_APPLYBQSR' {
        label = 'process_medium'
        // ApplyBQSR: applies recalibrated quality scores to BAM
        // DISABLED in DRAGEN-GATK mode — see conf/dragen_gatk.config
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Variant calling — DRAGEN-GATK HaplotypeCaller
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'GATK4_HAPLOTYPECALLER' {
        label = 'process_high'
        // HaplotypeCaller is single-threaded per interval; parallelised
        // by scattering over chromosome intervals (see wgs_grch38.nf)
        // DRAGEN-GATK mode flags are set in conf/dragen_gatk.config
        ext.args = [
            "--emit-ref-confidence GVCF",
            // Output GVCF for per-sample calling before joint genotyping
            "--tmp-dir /tmp",
            "--standard-min-confidence-threshold-for-calling 30",
            // GQ ≥ 30 for initial calling; VQSR handles final filtering
        ].join(" ")
    }

    withName: 'GATK4_GENOTYPEGVCFS' {
        label = 'process_high'
        // Joint genotyping across all samples' GVCFs
        // Memory scales with cohort size; 60 GB handles up to ~200 samples
    }

    withName: 'GATK4_VARIANTRECALIBRATOR' {
        label = 'process_medium'
        // VQSR training: ~16 GB RAM; benefits from --max-gaussians tuning
        // per-ancestry VQSR models are run separately (ancestry_vqsr=true)
    }

    withName: 'GATK4_APPLYVQSR' {
        label = 'process_medium'
        // Apply VQSR tranches to VCF — relatively lightweight
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Variant calling — DeepVariant v1.8.0
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'DEEPVARIANT_RUNDEEPVARIANT' {
        label = 'process_very_high'
        // DeepVariant v1.8.0 in CPU mode: 32 CPUs, ~50 GB RAM, 6-8h per sample
        // DeepVariant v1.8.0 in GPU mode: use process_deepvariant_gpu label
        // WGS model: --model_type=WGS (not WES or PACBIO)
        ext.args = "--model_type=WGS --output_gvcf={outdir}/{sample}.g.vcf.gz"
    }

    withName: 'DEEPVARIANT_RUNDEEPTRIO' {
        label = 'process_very_high'
        // DeepTrio v1.8.0: requires trio BAMs; ~3× DeepVariant runtime
        // Enabled only when run_deeptrio=true and PED file is provided
        ext.args = "--model_type=WGS"
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Ensemble variant calling
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'ENSEMBLE_MERGE' {
        label = 'process_medium'
        // Merge GATK HC and DeepVariant VCFs using SURVIVOR or custom logic
        // Variants called by both callers get PASS; single-caller gets WARN
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Annotation — VEP v111
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'ENSEMBLVEP_VEP' {
        label = 'process_high'
        // VEP v111 with MANE Select, dbNSFP v4.7, AlphaMissense, SpliceAI plugins
        // Memory: up to 40 GB with all plugins enabled
        // Runtime: ~2-4 hours per sample (30× WGS)
        ext.args = [
            "--everything",            // Enable all standard annotations
            "--mane",                  // MANE Select transcript annotation (primary for ACGS 2024)
            "--canonical",             // Mark canonical transcripts
            "--sift b",                // Include SIFT scores
            "--polyphen b",            // Include PolyPhen scores
            "--af_gnomADe",            // gnomAD exome allele frequencies
            "--af_gnomADg",            // gnomAD genome allele frequencies (v4.1)
            "--plugin dbNSFP,${params.dbnsfp_db},AlphaMissense_score,REVEL_score,ESM1b_score,SpliceAI_pred",
            "--plugin AlphaMissense,file=${params.alphamissense_tsv}",
            // AlphaMissense as primary PP3/BP4 evidence (ClinGen SVI 2024)
            "--check_existing",        // Report ClinVar IDs for known variants
            "--format vcf",
            "--output_file {output}",
            "--vcf",
            "--force_overwrite",
            "--cache",
            "--offline",               // No internet during pipeline run
            "--cache_version 111",     // Must be 111 — do not change
        ].join(" ")
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Coverage and QC
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'MOSDEPTH' {
        label = 'process_medium'
        // mosdepth v0.3.6: fast coverage calculation
        // Reports: mean, median, per-chromosome, per-exon coverage
        ext.args = "--quantize 0:1:15:500:"
        // Quantize to 4 coverage bands: 0, 1-14, 15-499, ≥500
        // 15× is the diploid calling minimum; 30× is ACGS 2024 minimum
    }

    withName: 'SAMTOOLS_FLAGSTAT' {
        label = 'process_low'
        // Read alignment summary statistics; lightweight
    }

    withName: 'SOMALIER_EXTRACT' {
        label = 'process_low'
        // somalier: extract sites for ancestry + relatedness inference
    }

    withName: 'SOMALIER_RELATE' {
        label = 'process_medium'
        // somalier: compute pairwise relatedness coefficients
        // Used for sample swap detection and per-ancestry VQSR grouping
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Repeat expansions
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'EXPANSIONHUNTER' {
        label = 'process_single'
        // ExpansionHunter v5.0 is single-threaded
        // 60-loci catalog; runtime ~1-2 hours on 30× WGS
        ext.args = "--analysis-mode streaming"
        // Streaming mode: lower memory, slightly slower — safe for large genomes
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Mitochondrial variant calling
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'GATK4_MUTECT2_MITO' {
        label = 'process_medium'
        // Mutect2 in mito mode: high depth, no normal sample needed
        // Settings from conf/dragen_gatk.config (mutect2_mito_args)
    }

    withName: 'HAPLOGREP3' {
        label = 'process_single'
        // Haplogrep3: mito haplogroup assignment; single-threaded, lightweight
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Pharmacogenomics
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'CYRIUS' {
        label = 'process_single'
        // Cyrius: CYP2D6 SV caller; single-threaded; ~30 min per sample
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Pangenome alignment — vg giraffe (only with -profile pangenome)
    // ─────────────────────────────────────────────────────────────────────────

    withName: 'VG_GIRAFFE' {
        label = 'process_very_high'
        // vg giraffe: requires HPRC v1.1 graph (~100 GB) in memory
        // 32 CPUs; 200+ GB RAM; 12-18 hours per 30× WGS sample
        // See ADR-004 for why vg giraffe over vg map
        ext.args = "-f {fastq_1} -f {fastq_2} -Z {graph} -d {dist} -m {min}"
    }

    withName: 'VG_SURJECT' {
        label = 'process_high'
        // vg surject: convert pangenome alignments to linear GRCh38 BAM
        // Required for variant calling and QC in linear reference space
    }

}
