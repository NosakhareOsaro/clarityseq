// =============================================================================
// conf/dragen_gatk.config
// =============================================================================
// DRAGEN-GATK mode configuration.
//
// CRITICAL: BQSR (Base Quality Score Recalibration) is DISABLED
// in this config. When using DRAGMAP + HaplotypeCaller DRAGEN-GATK
// mode, BQSR must NOT be run because:
// 1. HaplotypeCaller's BQD (Base Quality Dropoff) genotyping model
//    replaces BQSR by modelling systematic errors internally
// 2. Applying BQSR to DRAGMAP-aligned reads produces quality scores
//    incompatible with the BQD model, REDUCING accuracy
// Reference: Broad Institute DRAGEN-GATK documentation
// https://gatk.broadinstitute.org/hc/en-us/articles/4407897446939
//
// If you need BQSR (e.g., for BWA-MEM2 alignment), use -profile bwa_mem2
//
// DRAGEN-GATK mode is activated in HaplotypeCaller via:
//   --dragen-mode true
//   --use-pdhmm true
// These flags enable the DRAGEN-GATK BQD + PDHMM models.
//
// DRAGEN-GATK was released as GATK Best Practice in 2021 and supersedes
// the classic BWA-MEM2 + BQSR + GATK-HC workflow for Illumina WGS.
// =============================================================================

params {
    run_bqsr = false  // Disabled in DRAGEN-GATK mode — see header comment above

    // ── HaplotypeCaller DRAGEN-GATK flags ─────────────────────────────────────

    gatk_haplotypecaller_args = [
        "--dragen-mode",
        // Activate DRAGEN-GATK mode — enables BQD + PDHMM models
        // This is the key flag that enables the full DRAGEN-GATK workflow
        // Reference: https://gatk.broadinstitute.org/hc/en-us/articles/4407897446939

        "--use-pdhmm",
        // Enable the Pair HMM variant of the DRAGEN local assembly model
        // PDHMM = PairHMM with DRAGEN-like properties; higher sensitivity
        // for indels and complex variants in repetitive regions

        "--mapping-quality-threshold-for-genotyping", "20",
        // Ignore reads with MAPQ < 20 during genotyping
        // MAPQ 20 = 1% probability of wrong mapping location
        // DRAGMAP already assigns MAPQ based on alignment uniqueness

        "--disable-read-filter", "NotDuplicateReadFilter",
        // Allow reads marked as duplicates during active region assembly
        // Why: MarkDuplicates flags are approximate; some duplicates in
        // difficult regions are actually unique reads from repetitive loci
        // The BQD model handles this internally

        "--smith-waterman", "FASTEST_AVAILABLE",
        // Use AVX2-optimised Smith-Waterman if available; fall back to Java
        // Speeds up local realignment without affecting accuracy

        "--pairhmm-implementation", "FASTEST_AVAILABLE"
        // Use SIMD-optimised PairHMM implementation
    ].join(" ")

    // ── Variant filtration (DRAGEN-GATK style hard filters) ──────────────────
    // Per ACGS 2024 v1.2, VQSR is preferred over hard filters for cohorts.
    // Hard filters are applied only when VQSR cannot be run (small cohorts).
    // Thresholds from: https://gatk.broadinstitute.org/hc/en-us/articles/4407897446939

    hard_filter_snp_expr   = "QD < 2.0 || MQ < 40.0 || FS > 60.0 || SOR > 3.0 || MQRankSum < -12.5 || ReadPosRankSum < -8.0"
    // SNP hard filter expression — DRAGEN-GATK recommended thresholds
    // QD < 2.0: low quality-by-depth (likely artefact)
    // MQ < 40.0: low mapping quality
    // FS > 60.0: strand bias by Fisher's exact test
    // SOR > 3.0: strand odds ratio (alternative strand bias metric)

    hard_filter_indel_expr = "QD < 2.0 || FS > 200.0 || SOR > 10.0 || ReadPosRankSum < -20.0"
    // Indel hard filter expression — DRAGEN-GATK recommended thresholds
    // FS threshold is higher for indels (200 vs 60 for SNPs) per GATK docs

    // ── Mutect2 mito mode ─────────────────────────────────────────────────────
    // These settings are used by the GATK Mutect2 mito arm (run_mito=true)
    // per ACGS 2024 §6 mitochondrial variant interpretation guidelines

    mutect2_mito_args = [
        "--mitochondria-mode",
        // Enable mito-specific settings: no population priors, high sensitivity
        // for low-heteroplasmy variants, chrM-appropriate filters

        "--max-reads-per-alignment-start", "75",
        // chrM has extremely high read depth (hundreds to thousands ×)
        // Cap at 75 to prevent memory issues without losing sensitivity
        // This is the GATK-recommended value for mito calling

        "--annotation", "StrandBiasBySample"
        // Add per-sample strand bias for mito strand-asymmetric artefacts
    ].join(" ")

    mutect2_mito_min_het = 0.01
    // Minimum heteroplasmy fraction to report
    // 1% heteroplasmy is the ACGS 2024 §6 reporting threshold
    // Below 1% the variant may not be clinically significant
}
