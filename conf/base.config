// =============================================================================
// ClaritySeq — conf/base.config
// =============================================================================
// Per-label resource limits for all pipeline processes.
// Labels are assigned in conf/resources.config and individual module main.nf
// files. These limits act as MAXIMUMS — actual usage may be lower.
//
// Labels:
//   low       — lightweight tasks (fastq check, tabix, index)
//   medium    — standard bioinformatics processes (fastp, mosdepth)
//   high      — compute-intensive (GATK HaplotypeCaller, VEP annotation)
//   very_high — memory-intensive (DeepVariant GPU, vg giraffe pangenome)
//
// All resource values are upper bounds. Nextflow will rescale automatically
// on retry (via the errorStrategy in nextflow.config).
//
// Reference: Nextflow resource management docs
// https://www.nextflow.io/docs/latest/process.html#resources
// =============================================================================

process {

    // ─────────────────────────────────────────────────────────────────────────
    // low — lightweight tasks
    // Examples: bgzip, tabix, samtools index, file checks, MD5 checksums
    // Target runtime: < 30 minutes
    // ─────────────────────────────────────────────────────────────────────────
    withLabel: 'process_low' {
        cpus   = { check_max( 2                 , 'cpus'   ) }
        // 2 CPUs sufficient for I/O-bound tasks; more adds scheduling overhead
        memory = { check_max( 4.GB  * task.attempt, 'memory' ) }
        // 4 GB base; doubles on retry to handle unexpected edge cases
        time   = { check_max( 2.h   * task.attempt, 'time'   ) }
        // 2 hours is generous for index/compress operations on chr22
    }

    // ─────────────────────────────────────────────────────────────────────────
    // medium — standard bioinformatics processes
    // Examples: fastp trimming, mosdepth coverage, samtools sort, somalier
    // Target runtime: 30 minutes – 2 hours per sample
    // ─────────────────────────────────────────────────────────────────────────
    withLabel: 'process_medium' {
        cpus   = { check_max( 8                 , 'cpus'   ) }
        // 8 CPUs: fastp and samtools scale well up to 8 threads
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        // 16 GB accommodates most per-sample operations on 30× WGS data
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
        // 4 hours covers fastp + samtools sort on 100 GB FASTQ
    }

    // ─────────────────────────────────────────────────────────────────────────
    // high — compute-intensive processes
    // Examples: DRAGMAP alignment, GATK HaplotypeCaller, VEP v111 annotation,
    //           GATK MarkDuplicates, GATK GenotypeGVCFs, VQSR
    // Target runtime: 2–12 hours per sample
    // ─────────────────────────────────────────────────────────────────────────
    withLabel: 'process_high' {
        cpus   = { check_max( 16                , 'cpus'   ) }
        // 16 CPUs: DRAGMAP scales to 32+ but 16 is the sweet spot for cost/speed
        // GATK HaplotypeCaller is single-threaded per interval; parallelise by interval
        memory = { check_max( 60.GB * task.attempt, 'memory' ) }
        // 60 GB: GATK HC needs ~16 GB; 60 GB provides headroom for VEP with plugins
        // VEP with dbNSFP and AlphaMissense plugins can use 30-40 GB
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
        // 12 hours: DRAGMAP alignment of 30× WGS on 16 CPUs takes ~4-6 hours
    }

    // ─────────────────────────────────────────────────────────────────────────
    // very_high — memory-intensive processes
    // Examples: DeepVariant (GPU), vg giraffe pangenome alignment,
    //           GATK GenomicsDB import (large cohorts), DeepTrio
    // Target runtime: 4–24 hours
    // Note: GPU resources are requested separately via clusterOptions in
    //       specific process definitions when running DeepVariant with GPU
    // ─────────────────────────────────────────────────────────────────────────
    withLabel: 'process_very_high' {
        cpus   = { check_max( 32                , 'cpus'   ) }
        // 32 CPUs: vg giraffe and DeepVariant scale well to 32 threads
        // For GPU mode (DeepVariant), CPUs are for pre/post-processing
        memory = { check_max( 120.GB * task.attempt, 'memory' ) }
        // 120 GB: vg giraffe requires ~100-200 GB for HPRC graph; 120 GB is minimum
        // DeepVariant in CPU mode: ~50 GB; GPU mode: ~32 GB GPU VRAM
        time   = { check_max( 24.h   * task.attempt, 'time'   ) }
        // 24 hours: vg giraffe on 30× WGS with HPRC v1.1 graph takes 12-18 hours
    }

    // ─────────────────────────────────────────────────────────────────────────
    // single_cpu — single-threaded tools that cannot parallelise
    // Examples: ExpansionHunter, Cyrius, Haplogrep3
    // ─────────────────────────────────────────────────────────────────────────
    withLabel: 'process_single' {
        cpus   = { check_max( 1                 , 'cpus'   ) }
        // Single CPU — these tools do not support multi-threading
        memory = { check_max( 8.GB  * task.attempt, 'memory' ) }
        // 8 GB: ExpansionHunter uses ~4 GB; 8 GB provides safe headroom
        time   = { check_max( 6.h   * task.attempt, 'time'   ) }
        // 6 hours: ExpansionHunter on full genome at 30× takes ~1-2 hours
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Error strategy overrides by exit code
    // 137 = OOM kill (SIGKILL); 140 = timeout; 143 = SIGTERM (graceful kill)
    // 247 = memory exceeded (Slurm OOM); 1 = general error (may be transient)
    // On retry, Nextflow will use the label's memory/time * task.attempt
    // ─────────────────────────────────────────────────────────────────────────
    withLabel: 'error_ignore' {
        errorStrategy = 'ignore'
        // Use for optional processes where failure is acceptable
    }

    withLabel: 'error_retry' {
        errorStrategy = 'retry'
        maxRetries    = 3
        // Use for processes that fail transiently (network, spot interruption)
    }

}

// =============================================================================
// check_max function
// =============================================================================
// Prevents resource requests from exceeding the profile-specific maxima.
// This ensures pipeline requests never exceed the available hardware.
// Taken from nf-core pipeline template (MIT licence).
// =============================================================================
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1) {
                return params.max_memory as nextflow.util.MemoryUnit
            } else {
                return obj
            }
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1) {
                return params.max_time as nextflow.util.Duration
            } else {
                return obj
            }
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
