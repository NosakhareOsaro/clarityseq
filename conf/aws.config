// =============================================================================
// GenomeForge — conf/aws.config
// =============================================================================
// AWS Batch configuration for the GenomeForge pipeline.
// Used with -profile aws.
//
// Infrastructure created by Terraform (terraform/batch.tf, terraform/s3.tf).
// All AWS resources are in eu-west-2 (London) for NHS data residency.
//
// Cost optimisation:
//   - Spot fleet used for all compute (90% cheaper than on-demand)
//   - Spot interruption handling: Nextflow resumes from checkpoint
//   - Data transfer: within-region (S3 in eu-west-2 → Batch in eu-west-2)
//
// Before using this profile:
//   1. terraform apply (creates Batch job queue, compute env, S3 buckets)
//   2. Set AWS_ACCOUNT_ID, AWS_REGION in .env
//   3. Authenticate: aws sso login or aws configure
// =============================================================================

aws {
    region = params.awsregion ?: "eu-west-2"
    // eu-west-2 = AWS London region
    // NHS England DSPT requires UK data residency for patient-identifiable data

    batch {
        cliPath = "/usr/local/aws-cli/v2/current/bin/aws"
        // Path to AWS CLI v2 inside the pipeline container
        // AWS CLI v2 is installed in docker/Dockerfile.pipeline

        maxTransferAttempts = 3
        // Retry S3 data transfers up to 3 times on failure
        // Handles transient S3 throttling and network interruptions

        maxParallelTransfers = 8
        // Upload/download up to 8 files in parallel
        // Optimises S3 throughput for large BAM/VCF files

        delayBetweenAttempts = 10000
        // 10 second delay between S3 transfer retry attempts (milliseconds)
        // Gives S3 throttling time to subside before retry

        jobRole = "arn:aws:iam::${params.awsaccountid ?: System.getenv('AWS_ACCOUNT_ID')}:role/GenomeForgeNextflowJobRole"
        // IAM role assumed by Batch job containers
        // Permissions: S3 read/write on genomeforge-* buckets, ECR pull
        // Created by terraform/iam.tf

        volumes = ["/tmp"]
        // Mount /tmp inside Batch containers for temporary files
        // AWS Batch runs containers in Docker on ECS instances
    }
}

process {
    executor = "awsbatch"
    // Route all Nextflow processes through AWS Batch

    queue = "genomeforge-spot-queue"
    // AWS Batch job queue — created by terraform/batch.tf
    // This queue uses the Spot compute environment for cost savings
    // FIFO scheduling; priority inversely proportional to job age

    container = "${params.awsaccountid ?: System.getenv('AWS_ACCOUNT_ID')}.dkr.ecr.${params.awsregion ?: 'eu-west-2'}.amazonaws.com/genomeforge/pipeline:0.1.0"
    // ECR container image — built by `make docker-build` and pushed by CI
    // ECR repository created by terraform/ecr.tf

    // ── AWS-specific resource overrides ───────────────────────────────────────
    // These extend the base.config labels with AWS Batch-specific settings

    withLabel: 'process_high' {
        // c5.4xlarge: 16 vCPU, 32 GB RAM; cost-effective for DRAGMAP alignment
        // Spot price: ~$0.20-0.30/h (vs $0.68/h on-demand as of 2026)
        cpus   = 16
        memory = "60.GB"
        time   = "12.h"
    }

    withLabel: 'process_very_high' {
        // r5.8xlarge: 32 vCPU, 256 GB RAM; required for vg giraffe pangenome
        // Spot price: ~$0.60-0.90/h (vs $2.016/h on-demand as of 2026)
        cpus   = 32
        memory = "240.GB"
        time   = "24.h"
    }

    withLabel: 'process_deepvariant_gpu' {
        // p3.2xlarge: 8 vCPU, 61 GB RAM, 1× NVIDIA V100 GPU
        // DeepVariant GPU mode reduces per-sample time from ~6h to ~45min
        // Spot price: ~$0.90-1.20/h (vs $3.06/h on-demand as of 2026)
        cpus   = 8
        memory = "60.GB"
        time   = "4.h"
        // GPU resources are passed via containerOptions in the DeepVariant module
        containerOptions = "--runtime=nvidia --gpus=1"
    }
}

// =============================================================================
// S3 work directory settings
// =============================================================================
workDir = params.work_dir ?: "s3://genomeforge-nextflow-work/work"
// Nextflow work directory on S3
// All intermediate files are stored here during execution
// Cost: ~$0.023/GB/month (S3 Standard)
// IMPORTANT: Run `make clean-s3-work` after successful runs to avoid storage costs

// =============================================================================
// Fusion v2 (optional) — NXF_FUSION=1 enables S3-native file access
// =============================================================================
// When enabled, Fusion mounts S3 directly in the container without
// pre-copying files. Reduces transfer time and S3 costs.
// Requires Nextflow Tower / Seqera Platform for current Fusion support.
// TODO(genomeforge): Enable Fusion when Seqera Platform is configured
